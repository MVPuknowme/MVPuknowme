{
  "name": "aura-core",
  "version": "1.3.1-base-rate-demo",
  "private": true,
  "description": "Aura-Core SKYGRID runtime with public demo routes and Base rate utilization bands.",
  "main": "app.js",
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "build": "node -e \"console.log('Aura-Core runtime deployment: no static build required')\"",
    "vercel-build": "pnpm run build",
    "prod": "AURA_MODE=prod SKYGRID_TRACE=false SKYGRID_LEVEL=info NODE_ENV=production node app.js",
    "deploy": "pnpm run prod",
    "run.config": "node scripts/skygrid-run-config.mjs",
    "preflight:ai-build": "pnpm run run.config && pnpm run preflight:interference && pnpm run build",
    "preflight:interference": "node scripts/build-interference-preflight.mjs",
    "validator:health": "node scripts/validator-health-check.mjs",
    "node:ledger": "node scripts/build-node-ledger.mjs",
    "stripe:expansion-session": "node scripts/create-stripe-expansion-session.mjs",
    "debug:utility-billing": "node scripts/debug-utility-billing-architecture.mjs",
    "make.debug": "pnpm run debug:utility-billing",
    "test.config": "pnpm run run.config",
    "proof:postman": "node scripts/run-skygrid-postman-proof.mjs",
    "proof:postman:fallback": "node scripts/run-skygrid-postman-proof.mjs --fallback",
    "local:worker:start": "node scripts/skygrid-local-worker-start.mjs --approve-owner-test",
    "local:worker:proof": "node scripts/skygrid-local-worker-start.mjs",
    "local:worker:fallback": "node scripts/skygrid-local-worker-start.mjs --approve-owner-test --fallback",
    "eth:collection:draft": "node scripts/skygrid-ethereum-collection-draft.mjs",
    "local:ethereum:proof": "pnpm run local:worker:start && pnpm run eth:collection:draft",
    "route:probe": "node scripts/skygrid-route-option-probe.mjs",
    "route:probe:primary": "node scripts/skygrid-route-option-probe.mjs --scenario=primary",
    "route:probe:local": "node scripts/skygrid-route-option-probe.mjs --scenario=local",
    "route:probe:queue": "node scripts/skygrid-route-option-probe.mjs --scenario=queue",
    "route:probe:proof": "pnpm run route:probe:primary && pnpm run route:probe:local && pnpm run route:probe:queue"
  },
  "dependencies": {
    "ai": "^5.0.0",
    "stripe": "^14.0.0"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
