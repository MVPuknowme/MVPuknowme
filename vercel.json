{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "rm -rf node_modules ~/.local/share/pnpm/store && corepack enable && corepack prepare pnpm@10.23.0 --activate && pnpm config set registry https://registry.npmjs.org/ && pnpm install --no-frozen-lockfile",
  "buildCommand": "corepack enable && corepack prepare pnpm@10.23.0 --activate && pnpm run build",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/runtime?__path=/"
    },
    {
      "source": "/health.json",
      "destination": "/api/runtime?__path=/health.json"
    },
    {
      "source": "/api/health",
      "destination": "/api/runtime?__path=/api/health"
    },
    {
      "source": "/api/status",
      "destination": "/api/runtime?__path=/api/status"
    },
    {
      "source": "/api/intake",
      "destination": "/api/runtime?__path=/api/intake"
    },
    {
      "source": "/api/pacific-heart/ingest",
      "destination": "/api/runtime?__path=/api/pacific-heart/ingest"
    },
    {
      "source": "/api/skygrid/helm",
      "destination": "/api/runtime?__path=/api/skygrid/helm"
    },
    {
      "source": "/api/skygrid/provenance",
      "destination": "/api/runtime?__path=/api/skygrid/provenance"
    },
    {
      "source": "/api/skygrid/aws",
      "destination": "/api/runtime?__path=/api/skygrid/aws"
    },
    {
      "source": "/dispatch",
      "destination": "/api/runtime?__path=/dispatch"
    },
    {
      "source": "/scenarios",
      "destination": "/api/runtime?__path=/scenarios"
    },
    {
      "source": "/rates",
      "destination": "/api/runtime?__path=/rates"
    },
    {
      "source": "/base",
      "destination": "/api/runtime?__path=/base"
    },
    {
      "source": "/pay",
      "destination": "/api/runtime?__path=/pay"
    },
    {
      "source": "/highway",
      "destination": "/api/runtime?__path=/highway"
    },
    {
      "source": "/interface",
      "destination": "/api/runtime?__path=/interface"
    },
    {
      "source": "/api/pay/quote",
      "destination": "/api/runtime?__path=/api/pay/quote"
    },
    {
      "source": "/api/highway/status",
      "destination": "/api/runtime?__path=/api/highway/status"
    },
    {
      "source": "/api/highway/flasks",
      "destination": "/api/runtime?__path=/api/highway/flasks"
    },
    {
      "source": "/api/highway/postman",
      "destination": "/api/runtime?__path=/api/highway/postman"
    },
    {
      "source": "/api/stripe/device-link",
      "destination": "/api/runtime?__path=/api/stripe/device-link"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-SkyGrid-Network",
          "value": "Aura-Core"
        },
        {
          "key": "X-SkyGrid-Canonical-Domain",
          "value": "https://aurcore.skygrid-protocol.net"
        },
        {
          "key": "X-SkyGrid-Fallback-Domain",
          "value": "https://aura-core.vercel.app"
        },
        {
          "key": "X-Phoenix-Version",
          "value": "1.3.11-aurcore-domain-runtime"
        }
      ]
    }
  ]
}
