# SKYGRID Emergency Data On-Ramp / Aura-Core environment template
# Copy to .env locally and fill values in your secure local environment.
# Never commit real secrets, tokens, private keys, wallet seed phrases, or full secret exports.

# Runtime
NODE_ENV=development
AURA_MODE=dev
SKYGRID_TRACE=false
SKYGRID_LEVEL=info
SKYGRID_BASE_URL=https://skygrid-protocol.net

# OpenAI / project metadata
# Keep full project identifiers private unless explicitly approved for publication.
OPENAI_PROJECT_ID=proj_REDACTED
OPENAI_API_KEY=sk_REDACTED

# Vercel
VERCEL_TOKEN=REDACTED
VERCEL_PROJECT_ID=prj_REDACTED
VERCEL_ORG_ID=team_REDACTED

# AWS
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=REDACTED
AWS_SECRET_ACCESS_KEY=REDACTED
AWS_SESSION_TOKEN=REDACTED

# Stripe / payment quote-only staging
STRIPE_SECRET_KEY=sk_REDACTED
STRIPE_WEBHOOK_SECRET=whsec_REDACTED

# Public route checks
SKYGRID_HEALTH_PATH=/health.json
SKYGRID_HIGHWAY_STATUS_PATH=/api/highway/status
SKYGRID_QUOTE_PATH=/api/pay/quote?amount=25
